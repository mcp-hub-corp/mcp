{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api.mcp-hub.info/schemas/scan_result.schema.json",
  "title": "MCP Hub Scan Result Contract",
  "description": "Wire contract for /api/v1/scans/{id}/verdict/, /api/v1/scans/{id}/result/ and /api/v1/skill-scan/{id}/. The watchdog client (mcp-hub-security) validates every API response against this schema before reading risk_level.",
  "type": "object",
  "required": ["schema_version", "risk_level"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "2.0.0",
      "description": "Schema version. Bumped on breaking change; clients must check before reading."
    },
    "scan_id": {
      "type": "string",
      "minLength": 1,
      "description": "Scan identifier (UUID7 or stringified UUID)."
    },
    "risk_level": {
      "type": "string",
      "enum": ["safe", "low", "medium", "high", "critical"],
      "description": "Normalized risk level. 'safe' is the best level (replaces legacy 'none')."
    },
    "security_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "description": "Security score on a 0-100 scale (MCP scans)."
    },
    "score": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 10.0,
      "description": "Skill score on a 0-10 scale (SkillScan)."
    },
    "verdict": {
      "type": "string",
      "enum": ["safe", "warn", "block"],
      "description": "Optional aggregated verdict. Reserved for future use."
    },
    "safe": {
      "type": "boolean",
      "description": "true when score >= 80 and no critical findings."
    },
    "has_critical": {
      "type": "boolean",
      "description": "true when at least one critical finding is present (SkillScan)."
    },
    "finding_count": {
      "type": "integer",
      "minimum": 0
    },
    "critical_count": {"type": "integer", "minimum": 0},
    "high_count": {"type": "integer", "minimum": 0},
    "medium_count": {"type": "integer", "minimum": 0},
    "low_count": {"type": "integer", "minimum": 0},
    "is_unlocked": {"type": "boolean"},
    "capabilities": {
      "type": "array",
      "items": {"type": "string"}
    },
    "owasp_risks": {
      "type": "array",
      "items": {"type": "string"}
    },
    "findings_summary": {
      "type": "object",
      "additionalProperties": {"type": "integer", "minimum": 0}
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "severity": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low", "info"]
          },
          "title": {"type": "string"},
          "description": {"type": ["string", "null"]},
          "file_path": {"type": ["string", "null"]},
          "line_number": {"type": ["integer", "null"]},
          "vulnerability_class": {"type": ["string", "null"]},
          "cwe_id": {"type": ["string", "null"]},
          "remediation": {"type": ["string", "null"]},
          "is_blurred": {"type": "boolean"}
        }
      }
    },
    "summary_data": {
      "type": "object",
      "description": "Extended summary from scanner (capabilities, owasp_coverage, endpoints, ...)."
    },
    "skill_name": {"type": "string"},
    "credits_consumed": {"type": "integer", "minimum": 0},
    "credits_remaining": {"type": ["integer", "null"], "minimum": 0}
  },
  "additionalProperties": true
}
